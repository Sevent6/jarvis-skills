{
  "exchanges": {
    "binance": {
      "enabled": true,
      "type": "spot-futures",
      "api_key_env": "BINANCE_API_KEY",
      "secret_env": "BINANCE_SECRET"
    },
    "hyperliquid": {
      "enabled": true,
      "type": "perpetual",
      "wallet_env": "HYPERLIQUID_WALLET"
    },
    "base": {
      "enabled": true,
      "type": "chain",
      "rpc_env": "BASE_RPC"
    }
  },
  "default_leverage": 5,
  "max_position_pct": 10,
  "stop_loss_pct": 2,
  "take_profit_pct": 6
}